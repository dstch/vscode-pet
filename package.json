{
  "name": "vscode-pet",
  "displayName": "VS Code Pet",
  "description": "A virtual pet companion for VS Code",
  "version": "0.1.0",
  "publisher": "developer",
  "repository": {
    "type": "git",
    "url": "https://github.com/dstch/vscode-pet.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:pet.open",
    "onWebviewPanel:petView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pet.open",
        "title": "Pet: Open",
        "category": "Pet"
      }
    ],
    "views": {
      "petView": [
        {
          "type": "webview",
          "id": "petView.main",
          "name": "Pet",
          "icon": "media/icon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile-webview": "node scripts/build-webview.js",
    "watch-webview": "node scripts/build-webview.js --watch"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.88.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "css-loader": "^6.10.0",
    "esbuild": "^0.24.0",
    "html-webpack-plugin": "^5.6.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
